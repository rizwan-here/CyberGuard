<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main class="container wide">
  <%- include('../partials/flash') %>

  <section class="page-title flex-title">
    <div>
      <h1>Browser IoC Scanner</h1>
      <p>Automatically extract and check IP addresses, domains, URLs, and file hashes from any text or URL — then save threats directly to the repository.</p>
    </div>
    <a href="/iocs" class="btn ghost small">← Repository</a>
  </section>

  <section class="panel" id="inputPanel">
    <h2>📋 Paste Content to Scan</h2>
    <p class="muted">Paste any log output, email headers, network capture notes, or text containing potential IoCs. The scanner also pre-fills your browser's current URL.</p>

    <div class="scan-input-row">
      <textarea
        id="scanInput"
        rows="6"
        placeholder="Paste logs, email headers, URLs, or any text here...&#10;&#10;Example:&#10;  Connection from 192.168.1.1 to evil-domain.com&#10;  Redirect to http://malware-site.ru/payload.exe&#10;  Hash: 44d88612fea8a8f36de82e1278abb02f"
        spellcheck="false"
      ></textarea>
    </div>

    <div class="scan-actions">
      <button class="btn primary" id="btnScan">
        <span id="scanBtnText">🔍 Scan for IoCs</span>
      </button>
      <button class="btn ghost" id="btnClear">Clear</button>
      <span class="scan-hint muted" id="scanHint"></span>
    </div>

    <div class="quick-fills">
      <span class="muted" style="font-size:13px">Quick fill:</span>
      <button class="btn small ghost" id="qfUrl">Current URL</button>
      <button class="btn small ghost" id="qfReferrer">Referrer</button>
      <button class="btn small ghost" id="qfCookieDomains">Cookie Domains</button>
      <button class="btn small ghost" id="qfPerfEntries">Perf. Hosts</button>
    </div>
  </section>

  <section class="panel" id="resultsPanel" style="display:none">
    <div class="flex-title" style="margin-bottom:14px">
      <h2 style="margin:0">🧪 Scan Results</h2>
      <div class="result-summary" id="resultSummary"></div>
    </div>

    <div class="tab-bar" id="tabBar">
      <button class="tab active" data-filter="all">All</button>
      <button class="tab" data-filter="known_threat">⚠ Known Threats</button>
      <button class="tab" data-filter="vulnerable">🚨 Vulnerable</button>
      <button class="tab" data-filter="safe">✔ Safe</button>
      <button class="tab" data-filter="unknown">❓ Unknown</button>
    </div>

    <div class="table-panel" style="margin-top:14px">
      <table id="resultsTable">
        <thead>
          <tr>
            <th style="width:36px">
              <input type="checkbox" id="selectAll" title="Select all unknown indicators">
            </th>
            <th>Indicator</th>
            <th>Type</th>
            <th>Status</th>
            <th>Threat Info</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="resultsBody"></tbody>
      </table>
    </div>

    <% if (currentUser && currentUser.role === 'admin') { %>
    <div class="bulk-bar" id="bulkBar" style="display:none">
      <span id="bulkCount" class="muted">0 selected</span>
      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <select id="bulkSeverity" class="inline-select">
          <option value="Medium">Medium severity</option>
          <option value="Low">Low</option>
          <option value="High">High</option>
          <option value="Critical">Critical</option>
        </select>
        <input id="bulkThreatType" class="inline-input" placeholder="Threat type (e.g. C2, Phishing)" />
        <button class="btn primary" id="btnBulkSave">💾 Save Selected to Repository</button>
      </div>
    </div>
    <% } %>
  </section>

  <% if (currentUser && currentUser.role === 'admin') { %>
  <div class="modal-overlay" id="saveModal" style="display:none">
    <div class="modal-box">
      <div class="modal-header">
        <h3>Save IoC to Repository</h3>
        <button class="btn ghost small" id="closeModal">✕</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="modalValue" />
        <input type="hidden" id="modalType" />

        <div class="grid-form" style="gap:10px">
          <div>
            <label>Indicator</label>
            <input id="modalValueDisplay" readonly style="opacity:.7" />
          </div>
          <div>
            <label>IoC Type</label>
            <input id="modalTypeDisplay" readonly style="opacity:.7" />
          </div>
          <div>
            <label>Threat Type *</label>
            <input id="modalThreatType" placeholder="e.g. Malware C2, Phishing, Ransomware" required />
          </div>
          <div>
            <label>Severity</label>
            <select id="modalSeverity">
              <option value="Low">Low</option>
              <option value="Medium" selected>Medium</option>
              <option value="High">High</option>
              <option value="Critical">Critical</option>
            </select>
          </div>
          <div>
            <label>Confidence (0–100)</label>
            <input type="number" id="modalConfidence" min="0" max="100" value="70" />
          </div>
          <div>
            <label>Source</label>
            <input id="modalSource" value="Browser Scanner" />
          </div>
          <div>
            <label>Tags (comma-separated)</label>
            <input id="modalTags" placeholder="e.g. browser-detected, c2, phishing" />
          </div>
          <div>
            <label>Description</label>
            <textarea id="modalDescription" rows="3" placeholder="Optional notes about this indicator..."></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn" id="closeModal2">Cancel</button>
        <button class="btn primary" id="btnConfirmSave">💾 Save to Repository</button>
      </div>
    </div>
  </div>
  <% } %>

</main>

<style>
.scan-input-row { margin-bottom: 12px; }
.scan-input-row textarea { width: 100%; min-height: 140px; font-family: Consolas, Monaco, monospace; font-size: 13px; resize: vertical; }
.scan-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 14px; }
.scan-hint { font-size: 13px; }
.quick-fills { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; padding-top: 12px; border-top: 1px solid var(--border); }
.tab-bar { display: flex; gap: 6px; flex-wrap: wrap; }
.tab { padding: 7px 16px; border-radius: 8px; border: 1px solid var(--border); background: var(--panel-light); color: var(--muted); cursor: pointer; font-size: 13px; font-weight: 700; }
.tab.active { background: var(--primary-dark); border-color: var(--primary); color: #fff; }
.result-summary { display: flex; gap: 10px; flex-wrap: wrap; }
.result-chip { padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 800; border: 1px solid var(--border); }
.chip-threat { background: rgba(239,68,68,.13); color: #fca5a5; border-color: var(--danger); }
.chip-vulnerable { background: rgba(251,191,36,.12); color: #f59e0b; border-color: #f59e0b; }
.chip-safe { background: rgba(34,197,94,.12); color: #4ade80; border-color: #4ade80; }
.chip-unknown { background: rgba(245,158,11,.1); color: #fcd34d; border-color: var(--warning); }
.chip-total { background: rgba(56,189,248,.1); color: #7dd3fc; border-color: var(--primary); }
.status-badge { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 800; }
.status-known_threat { background: rgba(239,68,68,.15); color: #fca5a5; border: 1px solid var(--danger); }
.status-vulnerable { background: rgba(251,191,36,.12); color: #f59e0b; border: 1px solid #f59e0b; }
.status-safe { background: rgba(34,197,94,.15); color: #4ade80; border: 1px solid #4ade80; }
.status-unknown { background: rgba(245,158,11,.1); color: #fcd34d; border: 1px solid var(--warning); }
.status-saved { background: rgba(34,197,94,.15); color: #86efac; border: 1px solid var(--success); }
.bulk-bar { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-top: 16px; padding: 12px 16px; background: rgba(56,189,248,.06); border: 1px solid var(--primary); border-radius: 12px; }
.inline-select, .inline-input { padding: 8px 10px; border-radius: 8px; border: 1px solid var(--border); background: #0b1224; color: var(--text); font-size: 13px; }
.inline-input { width: 200px; }
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.65); display: flex; align-items: center; justify-content: center; z-index: 100; padding: 16px; }
.modal-box { background: var(--panel); border: 1px solid var(--border); border-radius: 18px; width: min(560px, 96vw); box-shadow: 0 24px 60px rgba(0,0,0,.5); overflow: hidden; }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 18px 22px; border-bottom: 1px solid var(--border); }
.modal-header h3 { margin: 0; }
.modal-body { padding: 20px 22px; max-height: 65vh; overflow-y: auto; }
.modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 14px 22px; border-top: 1px solid var(--border); }
tr.row-hidden { display: none; }
tr.row-saved td { opacity: .55; }
</style>

<script>
(function () {
  "use strict";

  const RE = {
    ipv4: /\b(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)(\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)){3}\b/g,
    ipv6: /\b([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\b|\b(([0-9a-fA-F]{1,4}:)*::([0-9a-fA-F]{1,4}:)*[0-9a-fA-F]{0,4})\b/g,
    url:  /https?:\/\/[^\s"'<>()[\]{}|\\^`\x00-\x1F]+/gi,
    domain: /\b(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\.)+(?:com|net|org|io|gov|edu|mil|biz|info|xyz|ru|cn|br|de|uk|fr|jp|nl|in|au|ca|co|cc|me|tv|us|eu|app|dev|online|site|tech|club|store|shop|top|pro|live|news|click|pw|tk|ml|ga|cf|gq|link|zip|mov|nexus|cyou|icu|vip|win|fun|email|cloud|space|host|solutions|systems)\b/gi,
    md5:    /\b[0-9a-fA-F]{32}\b/g,
    sha1:   /\b[0-9a-fA-F]{40}\b/g,
    sha256: /\b[0-9a-fA-F]{64}\b/g,
    email:  /\b[^\s@]+@[^\s@]+\.[^\s@]+\b/g
  };

  const IGNORE_IPS = [
    /^127\./, /^10\./, /^192\.168\./, /^172\.(1[6-9]|2\d|3[01])\./,
    /^169\.254\./, /^0\.0\.0\.0$/, /^255\.255\.255\.255$/
  ];

  function isPrivateIP(ip) { return IGNORE_IPS.some(re => re.test(ip)); }

  function extractIndicators(text) {
    const found = new Set();
    const urls = text.match(RE.url) || [];
    for (const u of urls) {
      found.add(u.toLowerCase());
      try { const host = new URL(u).hostname; if (host) found.add(host.toLowerCase()); } catch (_) {}
    }

    const ips4 = text.match(RE.ipv4) || [];
    for (const ip of ips4) { if (!isPrivateIP(ip)) found.add(ip); }
    const ips6 = text.match(RE.ipv6) || [];
    for (const ip of ips6) found.add(ip.toLowerCase());

    const h256 = text.match(RE.sha256) || [];
    for (const h of h256) found.add(h.toLowerCase());

    const h1 = text.match(RE.sha1) || [];
    for (const h of h1) { if (![...found].some(f => f.includes(h.toLowerCase()))) found.add(h.toLowerCase()); }

    const hm = text.match(RE.md5) || [];
    for (const h of hm) { if (![...found].some(f => f.includes(h.toLowerCase()))) found.add(h.toLowerCase()); }

    const emails = text.match(RE.email) || [];
    for (const e of emails) found.add(e.toLowerCase());

    const domains = text.match(RE.domain) || [];
    for (const d of domains) {
      const dl = d.toLowerCase();
      if (![...found].some(f => f === dl || f.endsWith("/" + dl))) found.add(dl);
    }
    return [...found].filter(Boolean);
  }

  // UPDATED: High-Speed Cinematic Decoder mapped to delays
  function animateDecryption(element, delayMs = 0) {
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+{}[]|:;<>,.?/~`";
    const finalValue = element.innerText.trim();
    element.dataset.value = finalValue;
    let iterations = 0;

    setTimeout(() => {
      const interval = setInterval(() => {
        element.innerText = finalValue.split("")
          .map((char, index) => {
            if(index < iterations) return finalValue[index];
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join("");

        if(iterations >= finalValue.length) clearInterval(interval);
        iterations += finalValue.length > 30 ? 4 : 2; // Fast character lock-in
      }, 15); // Fast tick interval
    }, delayMs);
  }

  let allResults = [];
  let currentFilter = "all";
  const isAdmin = !!document.getElementById("bulkBar");

  const scanInput       = document.getElementById("scanInput");
  const btnScan         = document.getElementById("btnScan");
  const btnClear        = document.getElementById("btnClear");
  const scanHint        = document.getElementById("scanHint");
  const resultsPanel    = document.getElementById("resultsPanel");
  const resultsBody     = document.getElementById("resultsBody");
  const resultSummary   = document.getElementById("resultSummary");
  const tabBar          = document.getElementById("tabBar");
  const selectAll       = document.getElementById("selectAll");
  const bulkBar         = document.getElementById("bulkBar");
  const bulkCount       = document.getElementById("bulkCount");
  const btnBulkSave     = document.getElementById("btnBulkSave");
  const saveModal       = document.getElementById("saveModal");

  document.getElementById("qfUrl").addEventListener("click", () => { scanInput.value += (scanInput.value ? "\n" : "") + window.location.href; });
  document.getElementById("qfReferrer").addEventListener("click", () => { const r = document.referrer || "(no referrer)"; scanInput.value += (scanInput.value ? "\n" : "") + r; });
  document.getElementById("qfCookieDomains").addEventListener("click", () => { const text = document.cookie || "(no accessible cookies)"; scanInput.value += (scanInput.value ? "\n" : "") + text; });
  document.getElementById("qfPerfEntries").addEventListener("click", () => {
    if (!window.performance || !performance.getEntriesByType) { scanInput.value += "\n(Performance API not available)"; return; }
    const entries = performance.getEntriesByType("resource");
    const hosts = [...new Set(entries.map(e => { try { return new URL(e.name).hostname; } catch (_) { return e.name; } }))];
    scanInput.value += (scanInput.value ? "\n" : "") + hosts.join("\n");
  });

  btnClear.addEventListener("click", () => { scanInput.value = ""; resultsPanel.style.display = "none"; allResults = []; scanHint.textContent = ""; });

  btnScan.addEventListener("click", async () => {
    const text = scanInput.value.trim();
    if (!text) { scanHint.textContent = "Please paste some content first."; return; }

    const indicators = extractIndicators(text);
    if (indicators.length === 0) { scanHint.textContent = "No recognisable IoCs found in the text."; return; }

    scanHint.textContent = `Extracted ${indicators.length} indicator(s). Checking repository…`;
    btnScan.disabled = true;
    document.getElementById("scanBtnText").textContent = "⏳ Scanning…";

    try {
      const resp = await fetch("/iocs/browser-detect", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ indicators }) });
      if (!resp.ok) throw new Error("Server error " + resp.status);
      const data = await resp.json();
      allResults = data.results || [];
      renderResults();
      scanHint.textContent = `Done — ${allResults.length} indicator(s) checked.`;
    } catch (err) { scanHint.textContent = "Error: " + err.message; } finally { btnScan.disabled = false; document.getElementById("scanBtnText").textContent = "🔍 Scan for IoCs"; }
  });

  function renderResults() {
    if (allResults.length === 0) { resultsPanel.style.display = "none"; return; }
    resultsPanel.style.display = "";
    resultsBody.innerHTML = "";

    const threats = allResults.filter(r => r.status === "known_threat");
    const vulnerable = allResults.filter(r => r.status === "vulnerable");
    const safe = allResults.filter(r => r.status === "safe");
    const unknowns = allResults.filter(r => r.status === "unknown");

    resultSummary.innerHTML = `
      <span class="result-chip chip-total">${allResults.length} extracted</span>
      ${threats.length ? `<span class="result-chip chip-threat">⚠ ${threats.length} known threat${threats.length > 1 ? "s" : ""}</span>` : ""}
      ${vulnerable.length ? `<span class="result-chip chip-vulnerable">🚨 ${vulnerable.length} vulnerable</span>` : ""}
      ${safe.length ? `<span class="result-chip chip-safe">✔ ${safe.length} safe</span>` : ""}
      ${unknowns.length ? `<span class="result-chip chip-unknown">❓ ${unknowns.length} unknown</span>` : ""}
    `;

    allResults.forEach((r, i) => {
      const row = document.createElement("tr");
      row.dataset.index = i;
      row.dataset.status = r.status;
      if (currentFilter !== "all" && r.status !== currentFilter) row.classList.add("row-hidden");

      const statusClass = "status-" + r.status;
      const statusLabel = r.status === "known_threat" ? "⚠ Known Threat" :
                          r.status === "vulnerable"   ? "🚨 Vulnerable" :
                          r.status === "safe"         ? "✔ Safe"        :
                          r.status === "saved"        ? "✔ Saved"       : "❓ Unknown";

      const threatInfo = r.iocRecord
        ? `<span class="badge ${r.iocRecord.severity.toLowerCase()}">${r.iocRecord.severity}</span>
           <span style="margin-left:6px;font-size:12px;color:var(--muted)">${escHtml(r.iocRecord.threatType)}</span>`
        : `<span style="color:var(--muted);font-size:12px">Not in repository</span>`;

      const actions = isAdmin
        ? (r.status === "saved" ? `<span class="muted" style="font-size:12px">Saved ✓</span>` : (r.status === "safe" ? `<span class="muted" style="font-size:12px">No action</span>` : `<button class="btn small primary" onclick="openSaveModal(${i})">💾 Save</button>`))
        : (r.status === "safe" ? `<span class="muted" style="font-size:12px">Safe</span>` : `<span class="muted" style="font-size:12px">Admin only</span>`);

      const checkbox = (isAdmin && (r.status === "unknown" || r.status === "vulnerable")) ? `<input type="checkbox" class="row-cb" data-index="${i}">` : "";

      row.innerHTML = `
        <td>${checkbox}</td>
        <td style="max-width: 320px;">
          <div class="mono wrap decode-text" style="font-size:12px;">${escHtml(r.value)}</div>
        </td>
        <td><span class="badge medium" style="font-size:11px">${escHtml(r.iocType)}</span></td>
        <td><span class="status-badge ${statusClass}">${statusLabel}</span></td>
        <td>${threatInfo}</td>
        <td><div class="actions">${actions}</div></td>
      `;
      resultsBody.appendChild(row);
    });

    // UPDATED: Sync Row Fade with Text Decode
    document.querySelectorAll('.decode-text:not(.decoded)').forEach((el, index) => {
        el.classList.add('decoded');
        const row = el.closest('tr');
        const delay = index * 60; // 60ms stagger per row

        if(row) {
          row.style.opacity = '0';
          row.style.animation = `fadeInRow 0.4s ease-out forwards ${delay}ms`;
        }
        animateDecryption(el, delay);
    });

    updateBulkBar();
  }

  tabBar.addEventListener("click", (e) => {
    const tab = e.target.closest(".tab");
    if (!tab) return;
    document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
    tab.classList.add("active");
    currentFilter = tab.dataset.filter;
    document.querySelectorAll("#resultsBody tr").forEach(row => {
      const show = currentFilter === "all" || row.dataset.status === currentFilter;
      row.classList.toggle("row-hidden", !show);
    });
    updateBulkBar();
  });

  selectAll && selectAll.addEventListener("change", () => {
    document.querySelectorAll(".row-cb").forEach(cb => {
      const row = cb.closest("tr");
      if (!row.classList.contains("row-hidden")) { cb.checked = selectAll.checked; }
    });
    updateBulkBar();
  });

  document.addEventListener("change", (e) => { if (e.target.classList.contains("row-cb")) updateBulkBar(); });

  function updateBulkBar() {
    if (!bulkBar) return;
    const checked = document.querySelectorAll(".row-cb:checked").length;
    bulkBar.style.display = checked > 0 ? "flex" : "none";
    bulkCount.textContent = `${checked} selected`;
  }

  btnBulkSave && btnBulkSave.addEventListener("click", async () => {
    const checkboxes = [...document.querySelectorAll(".row-cb:checked")];
    if (checkboxes.length === 0) return;

    const severity = document.getElementById("bulkSeverity") ? document.getElementById("bulkSeverity").value : "Medium";
    const threatType = (document.getElementById("bulkThreatType") && document.getElementById("bulkThreatType").value.trim()) || "Browser-Detected Threat";

    btnBulkSave.disabled = true;
    btnBulkSave.textContent = "⏳ Saving…";

    let saved = 0;
    for (const cb of checkboxes) {
      const i = parseInt(cb.dataset.index);
      const r = allResults[i];
      if (!r) continue;
      const ok = await saveIoc({ value: r.value, iocType: r.iocType, threatType, severity, confidence: 70, source: "Browser Scanner (Bulk)", tags: ["browser-detected", "bulk-save"] });
      if (ok) { allResults[i].status = "saved"; saved++; }
    }

    renderResults();
    btnBulkSave.disabled = false;
    btnBulkSave.textContent = "💾 Save Selected to Repository";
    scanHint.textContent = `${saved} indicator(s) saved to the repository.`;
  });

  window.openSaveModal = function (i) {
    if (!saveModal) return;
    const r = allResults[i];
    document.getElementById("modalValue").value = r.value;
    document.getElementById("modalType").value = r.iocType;
    document.getElementById("modalValueDisplay").value = r.value;
    document.getElementById("modalTypeDisplay").value = r.iocType;
    document.getElementById("modalThreatType").value = "";
    document.getElementById("modalSeverity").value = "Medium";
    document.getElementById("modalConfidence").value = 70;
    document.getElementById("modalSource").value = "Browser Scanner";
    document.getElementById("modalTags").value = "browser-detected";
    document.getElementById("modalDescription").value = "";

    saveModal.dataset.resultIndex = i;
    saveModal.style.display = "flex";
  };

  ["closeModal", "closeModal2"].forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener("click", () => { saveModal.style.display = "none"; }); });
  saveModal && saveModal.addEventListener("click", (e) => { if (e.target === saveModal) saveModal.style.display = "none"; });

  const btnConfirmSave = document.getElementById("btnConfirmSave");
  btnConfirmSave && btnConfirmSave.addEventListener("click", async () => {
    const threatType = document.getElementById("modalThreatType").value.trim();
    if (!threatType) { document.getElementById("modalThreatType").focus(); return; }

    btnConfirmSave.disabled = true;
    btnConfirmSave.textContent = "⏳ Saving…";

    const i = parseInt(saveModal.dataset.resultIndex);
    const ok = await saveIoc({
      value:       document.getElementById("modalValue").value,
      iocType:     document.getElementById("modalType").value,
      threatType,
      severity:    document.getElementById("modalSeverity").value,
      confidence:  document.getElementById("modalConfidence").value,
      source:      document.getElementById("modalSource").value,
      description: document.getElementById("modalDescription").value,
      tags:        document.getElementById("modalTags").value.split(",").map(t => t.trim()).filter(Boolean)
    });

    if (ok && i >= 0) {
      allResults[i].status = "saved";
      renderResults();
      saveModal.style.display = "none";
      scanHint.textContent = "IoC saved to repository successfully.";
    }

    btnConfirmSave.disabled = false;
    btnConfirmSave.textContent = "💾 Save to Repository";
  });

  async function saveIoc(payload) {
    try {
      const resp = await fetch("/iocs/browser-save", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
      if (!resp.ok) { const d = await resp.json().catch(() => ({})); alert("Save failed: " + (d.error || resp.statusText)); return false; }
      return true;
    } catch (err) { alert("Network error: " + err.message); return false; }
  }

  function escHtml(str) { return String(str || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
  if (window.location.href && window.location.href !== "about:blank") { scanInput.value = window.location.href; }

})();
</script>

