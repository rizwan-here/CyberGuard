<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<main class="container">
  <div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
    <h1>IoC Repository</h1>
    
    <div style="display: flex; gap: 10px;">
      <% if (user && user.role === 'admin') { %>
        <a href="/iocs/export" class="btn btn-success" style="background-color: var(--success); border-color: var(--success); color: #000;">⬇ Export for SIEM</a>
        <a href="/iocs/parse" class="btn btn-secondary" style="border-color: var(--primary); color: var(--primary);">📄 Parse Report</a>
        <a href="/iocs/add" class="btn btn-primary">+ Add New</a>
        <a href="/iocs/import" class="btn btn-secondary">Import CSV</a>
      <% } %>
    </div>
  </div>

  <%- include('../partials/flash') %>
  
  <section class="panel">
    <form action="/iocs" method="GET" class="filter-form">
      <input type="text" name="search" placeholder="Search value, threat..." value="<%= search || '' %>">
      <select name="severity">
        <option value="">All Severities</option>
        <option value="Low" <%= severity === 'Low' ? 'selected' : '' %>>Low</option>
        <option value="Medium" <%= severity === 'Medium' ? 'selected' : '' %>>Medium</option>
        <option value="High" <%= severity === 'High' ? 'selected' : '' %>>High</option>
        <option value="Critical" <%= severity === 'Critical' ? 'selected' : '' %>>Critical</option>
      </select>
      <select name="iocType">
        <option value="">All Types</option>
        <option value="IP" <%= iocType === 'IP' ? 'selected' : '' %>>IP</option>
        <option value="Domain" <%= iocType === 'Domain' ? 'selected' : '' %>>Domain</option>
        <option value="URL" <%= iocType === 'URL' ? 'selected' : '' %>>URL</option>
        <option value="MD5" <%= iocType === 'MD5' ? 'selected' : '' %>>MD5</option>
        <option value="SHA256" <%= iocType === 'SHA256' ? 'selected' : '' %>>SHA256</option>
      </select>
      <button type="submit" class="btn btn-primary">Filter</button>
      <a href="/iocs" class="btn btn-danger">Clear</a>
    </form>
  </section>

  <section class="panel table-panel">
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Value</th>
            <th>Type</th>
            <th>Threat Type</th>
            <th>Severity</th>
            <th>Tags</th>
            <% if (user && user.role === 'admin') { %>
              <th>Actions</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (iocs.length === 0) { %>
            <tr>
              <td colspan="6" style="text-align: center; color: var(--muted);">No IoCs found in the repository.</td>
            </tr>
          <% } else { %>
            <% iocs.forEach(ioc => { %>
              <tr>
                <td class="break-cell decode-text"><%= ioc.value %></td>
                <td><span class="badge badge-gray"><%= ioc.iocType %></span></td>
                <td><%= ioc.threatType %></td>
                <td>
                  <span class="badge badge-<%= ioc.severity.toLowerCase() %>"><%= ioc.severity %></span>
                </td>
                <td>
                  <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                  <% ioc.tags.forEach(tag => { %>
                    <span class="badge badge-gray" style="font-size: 10px;"><%= tag %></span>
                  <% }) %>
                  </div>
                </td>
                <% if (user && user.role === 'admin') { %>
                  <td style="white-space: nowrap;">
                    <a href="/iocs/<%= ioc._id %>/edit" class="btn btn-small secondary" style="margin-right: 5px;">Edit</a>
                    <form action="/iocs/<%= ioc._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this IoC?');">
                      <button type="submit" class="btn btn-small danger">Delete</button>
                    </form>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>